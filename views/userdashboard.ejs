<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu - Full Stack Cafe</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">

    <nav class="bg-green-800 shadow-lg sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/dashboard" class="flex items-center gap-2 group">
                        <span class="text-2xl group-hover:scale-110 transition-transform">🍔</span>
                        <span class="font-bold text-white text-xl tracking-wide">Full Stack Cafe</span>
                    </a>
                </div>

                <div class="hidden md:flex items-center space-x-4">
                    <% if (typeof user !== 'undefined' && user) { %>
                        <% if (user.role === 'admin') { %>
                            <a href="/admin" class="text-green-100 hover:text-white px-3 py-2 rounded-md font-medium transition">Live Orders</a>
                            <a href="/admin/menu" class="text-green-100 hover:text-white px-3 py-2 rounded-md font-medium transition">Edit Menu</a>
                        <% } else { %>
                            <a href="/dashboard" class="text-green-100 hover:text-white px-3 py-2 rounded-md font-medium transition">Menu</a>
                            <a href="/my-orders" class="text-green-100 hover:text-white px-3 py-2 rounded-md font-medium transition">My Orders</a>
                            <a href="/checkout" class="bg-green-600 hover:bg-green-500 text-white px-4 py-2 rounded-full font-bold shadow-md transition flex items-center gap-2">
                                🛒 <span id="cart-count">0</span>
                            </a>
                        <% } %>
                        <a href="/logout" class="text-red-300 hover:text-red-100 px-3 py-2 rounded-md font-medium transition ml-4">Logout</a>
                    <% } else { %>
                        <a href="/login" class="text-green-100 hover:text-white px-3 py-2 rounded-md font-medium transition">Login</a>
                    <% } %>
                </div>

                <div class="md:hidden flex items-center">
                    <% if (typeof user !== 'undefined' && user && user.role !== 'admin') { %>
                        <a href="/checkout" class="mr-4 text-white flex items-center gap-1 bg-green-600 px-3 py-1.5 rounded-full shadow-md">
                            🛒 <span id="mobile-cart-count" class="font-bold">0</span>
                        </a>
                    <% } %>
                    <button onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" class="text-green-100 hover:text-white focus:outline-none p-2">
                        <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden bg-green-900 border-t border-green-700 shadow-xl absolute w-full left-0">
            <div class="px-4 py-3 space-y-2">
                <% if (typeof user !== 'undefined' && user) { %>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin" class="block text-green-100 hover:text-white hover:bg-green-700 px-3 py-3 rounded-md font-medium text-lg border-b border-green-800">Live Orders</a>
                        <a href="/admin/menu" class="block text-green-100 hover:text-white hover:bg-green-700 px-3 py-3 rounded-md font-medium text-lg border-b border-green-800">Edit Menu</a>
                    <% } else { %>
                        <a href="/dashboard" class="block text-green-100 hover:text-white hover:bg-green-700 px-3 py-3 rounded-md font-medium text-lg border-b border-green-800">Browse Menu</a>
                        <a href="/my-orders" class="block text-green-100 hover:text-white hover:bg-green-700 px-3 py-3 rounded-md font-medium text-lg border-b border-green-800">My Orders</a>
                    <% } %>
                    <a href="/logout" class="block text-red-300 hover:text-red-100 hover:bg-green-700 px-3 py-3 rounded-md font-medium text-lg">Logout</a>
                <% } else { %>
                    <a href="/login" class="block text-green-100 hover:text-white hover:bg-green-700 px-3 py-3 rounded-md font-medium text-lg">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-8 mb-20 flex-grow">
        <div class="text-center mb-8 md:mb-12">
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-green-800 mb-2 md:mb-3">Today's Fresh Menu 🥗</h1>
            <p class="text-green-600 text-base md:text-lg">Delicious food made fresh for you.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            <% if (items && items.length > 0) { %>
                <% items.forEach(item => { %>
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden border border-green-100 flex flex-col h-full transition duration-300 <%= item.inStock === false ? 'opacity-75 grayscale-[40%]' : 'hover:shadow-2xl transform hover:-translate-y-1' %>">
                        
                        <div class="h-40 md:h-48 overflow-hidden relative group">
                            <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover <%= item.inStock !== false ? 'group-hover:scale-105' : '' %> transition duration-500">
                            
                            <% if (item.inStock === false) { %>
                                <div class="absolute inset-0 bg-white/40 backdrop-blur-[2px] flex items-center justify-center z-10">
                                    <span class="bg-red-600 text-white font-black px-3 py-1.5 md:px-4 md:py-2 rounded-lg transform -rotate-12 shadow-2xl tracking-widest text-base md:text-lg border-2 border-white">
                                        OUT OF STOCK
                                    </span>
                                </div>
                            <% } %>
                        </div>

                        <div class="p-5 md:p-6 flex flex-col flex-grow relative">
                            <div class="flex justify-between items-start md:items-baseline mb-2 gap-2">
                                <h3 class="text-lg md:text-xl font-bold text-gray-800 leading-tight"><%= item.name %></h3>
                                <span class="text-base md:text-lg font-bold text-green-600 bg-green-100 px-2 py-1 md:px-3 md:py-1 rounded-full whitespace-nowrap">₹<%= item.price %></span>
                            </div>
                            
                            <p class="text-gray-600 mb-4 md:mb-6 text-sm flex-grow leading-relaxed"><%= item.description %></p>
                            
                            <% if (item.inStock !== false) { %>
                                <div id="action-container-<%= item._id %>" class="w-full mt-auto">
                                    <button onclick="updateCartItem('<%= item._id %>', '<%= item.name %>', <%= item.price %>, 1)" 
                                        class="w-full bg-green-600 text-white font-bold py-2.5 md:py-3 rounded-lg hover:bg-green-700 transition duration-300 shadow-md active:scale-95 flex justify-center items-center gap-2 group text-sm md:text-base">
                                        <span class="group-hover:scale-110 transition-transform">🛒</span>
                                        <span>Add to Cart</span> 
                                    </button>
                                </div>
                            <% } else { %>
                                <div class="w-full mt-auto">
                                    <button disabled class="w-full bg-gray-200 text-gray-500 font-bold py-2.5 md:py-3 rounded-lg cursor-not-allowed flex justify-center items-center gap-2 border border-gray-300 text-sm md:text-base">
                                        <span>🚫 Unavailable</span> 
                                    </button>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-1 sm:col-span-2 lg:col-span-3 text-center py-12 md:py-16 bg-white rounded-lg border-2 border-dashed border-gray-300 mx-4 md:mx-0">
                    <p class="text-gray-400 text-lg md:text-xl font-bold">The menu is empty right now. 🍽️</p>
                </div>
            <% } %>
        </div>
    </main>

    <footer class="bg-gray-800 text-white text-center py-6 mt-auto">
        <p class="text-gray-400 text-sm">&copy; 2026 Full Stack Cafe. All rights reserved.</p>
    </footer>

    <script>
        // MASTER FUNCTION TO HANDLE ADD/REMOVE
        function updateCartItem(id, name, price, change) {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            let existingItem = cart.find(item => item.id === id);

            if (existingItem) {
                existingItem.quantity += change;
                // Remove if quantity drops to 0
                if (existingItem.quantity <= 0) {
                    cart = cart.filter(item => item.id !== id);
                }
            } else if (change > 0) {
                // Add new item
                cart.push({ id, name, price, quantity: 1 });
            }

            // Save back to storage
            localStorage.setItem('cart', JSON.stringify(cart));
            
            // Update Header Badges immediately
            updateHeaderCart();
            
            // Update the button on the UI
            renderButton(id, name, price);
        }

        // RENDER BUTTON UI (Switches between "Add" and "- 1 +")
        function renderButton(id, name, price) {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const item = cart.find(i => i.id === id);
            const container = document.getElementById(`action-container-${id}`);

            if (!container) return;

            if (item) {
                // SHOW QUANTITY CONTROLS
                container.innerHTML = `
                    <div class="flex items-center justify-between bg-green-50 border-2 border-green-500 rounded-lg overflow-hidden shadow-sm h-[44px] md:h-[52px]">
                        <button onclick="updateCartItem('${id}', '${name}', ${price}, -1)" 
                            class="px-3 md:px-4 py-2 bg-green-100 hover:bg-green-200 text-green-800 font-bold transition w-1/3 text-lg h-full">-</button>
                        
                        <span class="font-bold text-green-900 w-1/3 text-center text-base md:text-lg">${item.quantity}</span>
                        
                        <button onclick="updateCartItem('${id}', '${name}', ${price}, 1)" 
                            class="px-3 md:px-4 py-2 bg-green-600 hover:bg-green-700 text-white font-bold transition w-1/3 text-lg h-full">+</button>
                    </div>
                `;
            } else {
                // SHOW ADD TO CART BUTTON
                container.innerHTML = `
                    <button onclick="updateCartItem('${id}', '${name}', ${price}, 1)" 
                        class="w-full bg-green-600 text-white font-bold py-2.5 md:py-3 rounded-lg hover:bg-green-700 transition duration-300 shadow-md active:scale-95 flex justify-center items-center gap-2 group text-sm md:text-base h-[44px] md:h-[52px]">
                        <span class="group-hover:scale-110 transition-transform">🛒</span>
                        <span>Add to Cart</span> 
                    </button>
                `;
            }
        }

        // COUNTS ITEMS FOR NAVBAR CART BADGE
        function updateHeaderCart() {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            
            const desktopBadge = document.getElementById('cart-count');
            const mobileBadge = document.getElementById('mobile-cart-count');
            
            if (desktopBadge) desktopBadge.innerText = totalItems;
            if (mobileBadge) mobileBadge.innerText = totalItems;
        }

        // INITIALIZE UI ON PAGE LOAD
        document.addEventListener('DOMContentLoaded', () => {
            updateHeaderCart(); // Update nav badges

            const containers = document.querySelectorAll('[id^="action-container-"]');
            containers.forEach(div => {
                const id = div.id.replace('action-container-', '');
                const btn = div.querySelector('button');
                
                if (btn) {
                    const onclickText = btn.getAttribute('onclick');
                    if(onclickText) {
                        const args = onclickText.match(/'([^']+)',\s*'([^']+)',\s*([\d.]+)/);
                        if (args) {
                            const [_, itemId, itemName, itemPrice] = args;
                            renderButton(itemId, itemName, itemPrice);
                        }
                    }
                }
            });
        });
    </script>
</body>
</html>