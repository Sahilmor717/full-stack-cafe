<%- include('header') %>

<main class="container mx-auto px-4 py-8 mb-20">
    
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-green-800">My Orders 📦</h1>
            <p class="text-gray-500 text-sm mt-1">Track your live orders and view your history.</p>
        </div>
        <a href="/dashboard" class="text-green-600 hover:text-green-800 font-bold flex items-center gap-1 hover:underline">
            <span>←</span> Menu
        </a>
    </div>

    <h2 class="text-2xl font-bold text-blue-700 mb-4 flex items-center gap-2">
        <span>🔥</span> Active Orders (<%= activeOrders ? activeOrders.length : 0 %>)
    </h2>
    <div class="bg-white shadow-lg rounded-xl overflow-hidden border border-blue-200 mb-12">
        <div class="overflow-x-auto">
            <table class="min-w-full w-full table-auto">
                <thead class="bg-blue-50 text-blue-800 uppercase text-xs font-bold tracking-wider">
                    <tr>
                        <th class="py-3 px-6 text-left">Date & Time</th>
                        <th class="py-3 px-6 text-left">Items Ordered</th>
                        <th class="py-3 px-6 text-center">Total Price</th>
                        <th class="py-3 px-6 text-center">Live Status</th>
                    </tr>
                </thead>
                <tbody class="text-gray-700 text-sm">
                    <% if (activeOrders && activeOrders.length > 0) { %>
                        <% activeOrders.forEach(order => { %>
                            <tr class="border-b border-gray-100 hover:bg-blue-50/50 transition duration-150">
                                <td class="py-4 px-6">
                                    <span class="font-bold text-gray-800 block"><%= order.createdAt.toLocaleDateString() %></span>
                                    <span class="text-xs text-gray-500"><%= order.createdAt.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                                </td>
                                
                                <td class="py-4 px-6">
                                    <ul class="space-y-1">
                                        <% order.items.forEach(item => { %>
                                            <li class="flex items-center gap-2">
                                                <span class="bg-blue-100 text-blue-800 text-xs font-bold px-2 py-0.5 rounded-full"><%= item.quantity %>x</span>
                                                <span class="font-medium"><%= item.name %></span>
                                            </li>
                                        <% }) %>
                                    </ul>
                                </td>

                                <td class="py-4 px-6 text-center">
                                    <span class="font-bold text-lg text-green-700">₹<%= order.totalAmount %></span>
                                </td>

                                <td class="py-4 px-6 text-center">
                                    <% if (order.status === 'Pending') { %>
                                        <span class="bg-yellow-100 text-yellow-800 py-1 px-3 rounded-full text-xs font-bold border border-yellow-200 animate-pulse">⏳ Pending</span>
                                    <% } else if (order.status === 'Accepted') { %>
                                        <span class="bg-blue-100 text-blue-800 py-1 px-3 rounded-full text-xs font-bold border border-blue-200 shadow-sm">👍 Accepted</span>
                                    <% } else if (order.status === 'Preparing') { %>
                                        <span class="bg-orange-100 text-orange-800 py-1 px-3 rounded-full text-xs font-bold border border-orange-200 shadow-sm">👨‍🍳 Preparing...</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="py-8 text-center text-gray-400">
                                You have no active orders right now.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <h2 class="text-2xl font-bold text-gray-700 mb-4 flex items-center gap-2">
        <span>📦</span> Order History (<%= pastOrders ? pastOrders.length : 0 %>)
    </h2>
    <div class="bg-white shadow-lg rounded-xl overflow-hidden border border-gray-200">
        <div class="overflow-x-auto">
            <table class="min-w-full w-full table-auto">
                <thead class="bg-gray-100 text-gray-700 uppercase text-xs font-bold tracking-wider">
                    <tr>
                        <th class="py-3 px-6 text-left">Date & Time</th>
                        <th class="py-3 px-6 text-left">Items Ordered</th>
                        <th class="py-3 px-6 text-center">Total Price</th>
                        <th class="py-3 px-6 text-center">Status & Actions</th>
                    </tr>
                </thead>
                <tbody class="text-gray-700 text-sm">
                    <% if (pastOrders && pastOrders.length > 0) { %>
                        <% pastOrders.forEach(order => { %>
                            <tr class="border-b border-gray-100 bg-gray-50 hover:bg-gray-100 transition duration-150">
                                <td class="py-4 px-6">
                                    <span class="font-bold text-gray-600 block"><%= order.createdAt.toLocaleDateString() %></span>
                                    <span class="text-xs text-gray-400"><%= order.createdAt.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                                </td>
                                
                                <td class="py-4 px-6 text-gray-600">
                                    <ul class="space-y-1">
                                        <% order.items.forEach(item => { %>
                                            <li class="flex items-center gap-2">
                                                <span class="bg-gray-300 text-gray-700 text-xs font-bold px-2 py-0.5 rounded-full"><%= item.quantity %>x</span>
                                                <span><%= item.name %></span>
                                            </li>
                                        <% }) %>
                                    </ul>
                                </td>

                                <td class="py-4 px-6 text-center">
                                    <span class="font-bold text-lg text-gray-600">₹<%= order.totalAmount %></span>
                                </td>

                                <td class="py-4 px-6 text-center flex flex-col items-center gap-3">
                                    <% if (order.status === 'Delivered' || order.status === 'Completed') { %>
                                        <span class="bg-green-100 text-green-700 py-1 px-3 rounded-full text-xs font-bold border border-green-200">✅ Delivered</span>
                                        
                                        <button 
                                            onclick="reorder(this)" 
                                            data-items="<%= JSON.stringify(order.items) %>"
                                            class="bg-green-600 hover:bg-green-700 text-white text-xs font-bold px-4 py-2 rounded shadow-md transition transform active:scale-95 flex items-center gap-1">
                                            <span>Reorder</span> 🛒
                                        </button>

                                    <% } else if (order.status === 'Cancelled') { %>
                                        <span class="bg-red-100 text-red-700 py-1 px-3 rounded-full text-xs font-bold border border-red-200">❌ Cancelled</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="py-12 text-center text-gray-400">
                                You have no past orders.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<script>
    // REORDER LOGIC
    function reorder(buttonElement) {
        // Parse the items attached to the button
        const orderItems = JSON.parse(buttonElement.getAttribute('data-items'));
        let cart = JSON.parse(localStorage.getItem('cart')) || [];

        // Add each item to the cart
        orderItems.forEach(orderItem => {
            let existingItem = cart.find(cartItem => cartItem.name === orderItem.name);
            if (existingItem) {
                existingItem.quantity += orderItem.quantity;
            } else {
                cart.push({
                    id: orderItem._id || orderItem.name, 
                    name: orderItem.name,
                    price: orderItem.price,
                    quantity: orderItem.quantity
                });
            }
        });

        // Save back to local storage
        localStorage.setItem('cart', JSON.stringify(cart));

        // Update the header badge if the function exists
        if (typeof updateHeaderCart === 'function') {
            updateHeaderCart();
        }

        // Redirect to checkout
        window.location.href = '/checkout';
    }
</script>

<%- include('footer') %>