<%- include('header') %>

<main class="container mx-auto px-4 py-8">
    
    <div class="bg-white p-6 rounded-lg shadow-sm border-l-4 border-blue-600 mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">Menu Management 📋</h1>
            <div class="mt-4 flex gap-4">
                <a href="/admin" class="bg-gray-100 text-gray-600 hover:bg-gray-200 px-4 py-2 rounded font-bold transition">Orders</a>
                <a href="/admin/menu" class="bg-blue-600 text-white px-4 py-2 rounded font-bold shadow-md">Manage Menu</a>
            </div>
        </div>
        <span class="bg-blue-100 text-blue-800 text-sm font-bold px-4 py-2 rounded-full border border-blue-200">Owner Mode</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-1">
            <div class="bg-white shadow-lg rounded-xl overflow-hidden border border-blue-100 p-6 sticky top-24">
                <h2 class="text-xl font-bold text-blue-800 mb-4 pb-2 border-b border-gray-100">Add New Item 🍔</h2>
                
                <form action="/admin/add-item" method="POST" enctype="multipart/form-data" class="space-y-4">
                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-1">Item Name</label>
                        <input type="text" name="name" required placeholder="e.g. Veg Burger" class="w-full border border-gray-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>

                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-1">Price (₹)</label>
                        <input type="number" name="price" step="1" required placeholder="e.g. 50" class="w-full border border-gray-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>

                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-1">Description</label>
                        <textarea name="description" required rows="2" placeholder="Short description..." class="w-full border border-gray-300 p-2 rounded focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
                    </div>

                    <div>
                        <label class="block text-gray-700 text-sm font-bold mb-1">Image</label>
                        <input type="file" name="image" accept="image/*" required class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
                    </div>

                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg transition duration-300 shadow-md">
                        + Add to Menu
                    </button>
                </form>
            </div>
        </div>

        <div class="lg:col-span-2">
            <h3 class="text-2xl font-bold text-gray-800 mb-6">Current Menu (<%= items.length %> Items)</h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <% if (items.length > 0) { %>
                    <% items.forEach(item => { %>
                        <div class="bg-white rounded-lg shadow-md border border-gray-200 flex overflow-hidden relative <%= item.inStock === false ? 'opacity-75 grayscale-[50%]' : '' %>">
                            <img src="<%= item.image %>" class="w-1/3 object-cover">
                            
                            <div class="p-4 w-2/3 flex flex-col justify-center">
                                <h4 class="font-bold text-lg text-gray-800 truncate"><%= item.name %></h4>
                                <span class="text-sm font-bold text-green-600 mb-2">₹<%= item.price %></span>
                                <p class="text-xs text-gray-500 line-clamp-2 mb-3"><%= item.description %></p>
                                
                                <form action="/admin/toggle-stock/<%= item._id %>" method="POST">
                                    <button type="submit" class="text-xs font-bold px-3 py-1.5 rounded w-full transition shadow-sm <%= item.inStock !== false ? 'bg-red-50 text-red-600 hover:bg-red-100 border border-red-200' : 'bg-green-100 text-green-700 hover:bg-green-200 border border-green-300' %>">
                                        <%= item.inStock !== false ? '⏸ Mark Out of Stock' : '▶️ Mark as Available' %>
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-2 text-center py-12 text-gray-400 bg-white rounded-lg border-2 border-dashed border-gray-300">
                        No items in the menu. Add one using the form!
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</main>

<%- include('footer') %>