<%- include('header') %>

<main class="container mx-auto px-4 py-8">
    
    <div class="bg-white p-6 rounded-lg shadow-sm border-l-4 border-green-600 mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">Admin Dashboard 👨‍🍳</h1>
            <div class="mt-4 flex gap-4">
                <a href="/admin" class="bg-green-600 text-white px-4 py-2 rounded font-bold shadow-md">Live Orders</a>
                <a href="/admin/menu" class="bg-gray-100 text-gray-600 hover:bg-gray-200 px-4 py-2 rounded font-bold transition">Manage Menu</a>
            </div>
        </div>
        <span class="bg-green-100 text-green-800 text-sm font-bold px-4 py-2 rounded-full border border-green-200">Owner Mode</span>
    </div>

    <h2 class="text-2xl font-bold text-blue-700 mb-4 flex items-center gap-2">
        <span>🔥</span> Active Orders (<%= activeOrders.length %>)
    </h2>
    <div class="bg-white shadow-lg rounded-xl overflow-hidden border border-blue-200 mb-12">
        <table class="min-w-full w-full table-auto">
            <thead class="bg-blue-50 text-blue-800 uppercase text-xs font-bold">
                <tr>
                    <th class="py-3 px-4 text-left">ID & Time</th>
                    <th class="py-3 px-4 text-left">Customer</th>
                    <th class="py-3 px-4 text-left">Items</th>
                    <th class="py-3 px-4 text-center">Current Status</th>
                    <th class="py-3 px-4 text-center">Update Status</th>
                </tr>
            </thead>
            <tbody class="text-gray-600 text-sm">
                <% if (activeOrders.length > 0) { %>
                    <% activeOrders.forEach(order => { %>
                        <tr class="border-b border-gray-100 hover:bg-blue-50/50">
                            <td class="py-3 px-4 font-mono text-xs">
                                <b>#<%= order._id.toString().slice(-4) %></b><br>
                                <span class="text-gray-400"><%= order.createdAt.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></span>
                            </td>
                            <td class="py-3 px-4 font-bold"><%= order.user ? order.user.name : 'Guest' %></td>
                            <td class="py-3 px-4">
                                <% order.items.forEach(item => { %>
                                    <div class="text-xs">• <%= item.quantity %>x <%= item.name %></div>
                                <% }) %>
                            </td>
                            <td class="py-3 px-4 text-center font-bold text-green-700">
                                <span class="bg-gray-100 text-gray-800 px-2 py-1 rounded text-xs"><%= order.status %></span>
                            </td>
                            <td class="py-3 px-4 text-center">
                                <form action="/admin/update-order/<%= order._id %>" method="POST" class="flex gap-2 items-center justify-center">
                                    <select name="status" class="border border-gray-300 rounded px-2 py-1 text-sm outline-none bg-white">
                                        <option value="Pending" <%= order.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                        <option value="Accepted" <%= order.status === 'Accepted' ? 'selected' : '' %>>Accepted</option>
                                        <option value="Preparing" <%= order.status === 'Preparing' ? 'selected' : '' %>>Preparing</option>
                                        <option value="Delivered" <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                                        <option value="Cancelled" <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
                                    </select>
                                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-1 px-3 rounded shadow transition text-sm">
                                        Save
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="5" class="py-8 text-center text-gray-400">No active orders right now.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <h2 class="text-2xl font-bold text-gray-700 mb-4 flex items-center gap-2">
        <span>📦</span> Order History (<%= pastOrders.length %>)
    </h2>
    <div class="bg-white shadow-lg rounded-xl overflow-hidden border border-gray-200 opacity-90">
        <table class="min-w-full w-full table-auto">
            <thead class="bg-gray-100 text-gray-700 uppercase text-xs font-bold">
                <tr>
                    <th class="py-3 px-4 text-left">ID & Time</th>
                    <th class="py-3 px-4 text-left">Customer</th>
                    <th class="py-3 px-4 text-left">Items</th>
                    <th class="py-3 px-4 text-center">Total</th>
                    <th class="py-3 px-4 text-center">Status</th>
                </tr>
            </thead>
            <tbody class="text-gray-600 text-sm">
                <% if (pastOrders.length > 0) { %>
                    <% pastOrders.forEach(order => { %>
                        <tr class="border-b border-gray-100">
                            <td class="py-3 px-4 font-mono text-xs">
                                <b>#<%= order._id.toString().slice(-4) %></b><br>
                                <%= order.createdAt.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                            </td>
                            <td class="py-3 px-4 font-medium"><%= order.user ? order.user.name : 'Guest' %></td>
                            <td class="py-3 px-4 text-gray-500">
                                <% order.items.forEach(item => { %>
                                    <div class="text-xs">• <%= item.quantity %>x <%= item.name %></div>
                                <% }) %>
                            </td>
                            <td class="py-3 px-4 text-center font-bold text-gray-600">₹<%= order.totalAmount %></td>
                            <td class="py-3 px-4 text-center">
                                <% if (order.status === 'Delivered') { %>
                                    <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-bold">Delivered</span>
                                <% } else { %>
                                    <span class="bg-red-100 text-red-700 px-2 py-1 rounded text-xs font-bold">Cancelled</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr><td colspan="5" class="py-8 text-center text-gray-400">No past orders.</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</main>

<%- include('footer') %>